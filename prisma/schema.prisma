generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───

enum UserRole {
  USER
  COACH
  VENUE_OWNER
  ACADEMY_OWNER
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum GameStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventType {
  TOURNAMENT
  LEAGUE
  CLINIC
  CAMP
  SOCIAL
  WORKSHOP
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FORFEIT
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLATION
  GAME_INVITATION
  GAME_UPDATE
  GAME_REMINDER
  EVENT_UPDATE
  PAYMENT_RECEIPT
  REVIEW_RECEIVED
  ACHIEVEMENT_UNLOCKED
  GENERAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── User & Profile ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(USER)
  bio           String?   @db.Text
  city          String?
  state         String?
  zipCode       String?
  skillLevel    String?
  isActive      Boolean   @default(true)
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  bookings             Booking[]
  organizedGames       PickupGame[]
  gameParticipations   PickupGameParticipant[]
  coachProfile         Coach?
  reviews              Review[]
  ownedVenues          Venue[]
  ownedAcademies       Academy[]
  enrollments          Enrollment[]
  attendances          Attendance[]
  coachSessions        CoachSession[]         @relation("StudentSessions")
  favorites            Favorite[]
  achievements         PlayerBadge[]
  notifications        Notification[]
  sentMessages         Message[]              @relation("SentMessages")
  receivedMessages     Message[]              @relation("ReceivedMessages")
  groupMemberships     GroupMember[]
  ownedGroups          Group[]
  eventRegistrations   EventRegistration[]
  blogPosts            BlogPost[]
  auditLogs            AuditLog[]
}

// ─── Sports ───

model Sport {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  venueSports       VenueSport[]
  coachSports       CoachSport[]
  pickupGames       PickupGame[]
  academySports     AcademySport[]
  events            Event[]
}

// ─── Venues ───

model Venue {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  address      String
  city         String
  state        String
  zipCode      String
  lat          Float?
  lng          Float?
  phone        String?
  email        String?
  website      String?
  pricePerHour Float
  amenities    String[] @default([])
  rules        String?  @db.Text
  openTime     String?
  closeTime    String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  ownerId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id])
  sports      VenueSport[]
  images      VenueImage[]
  bookings    Booking[]
  pickupGames PickupGame[]
  events      Event[]
  reviews     Review[]

  @@index([city, state])
  @@index([isActive])
}

model VenueSport {
  venueId String
  sportId String

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([venueId, sportId])
}

model VenueImage {
  id        String  @id @default(cuid())
  venueId   String
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

// ─── Bookings & Payments ───

model Booking {
  id          String        @id @default(cuid())
  venueId     String
  userId      String
  startAt     DateTime
  endAt       DateTime
  totalAmount Float?
  notes       String?
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  venue   Venue    @relation(fields: [venueId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  payment Payment?

  @@index([venueId, startAt, endAt])
  @@index([userId])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String?       @unique
  enrollmentId          String?       @unique
  coachSessionId        String?       @unique
  eventRegistrationId   String?       @unique
  stripePaymentIntentId String?       @unique
  amount                Int
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  refundedAmount        Int?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  booking           Booking?           @relation(fields: [bookingId], references: [id])
  enrollment        Enrollment?        @relation(fields: [enrollmentId], references: [id])
  coachSession      CoachSession?      @relation(fields: [coachSessionId], references: [id])
  eventRegistration EventRegistration? @relation(fields: [eventRegistrationId], references: [id])
}

// ─── Pickup Games ───

model PickupGame {
  id           String     @id @default(cuid())
  sportId      String
  venueId      String?
  organizerId  String
  title        String
  description  String?    @db.Text
  location     String?
  city         String?
  state        String?
  skillLevel   String?
  startAt      DateTime
  endAt        DateTime
  maxPlayers   Int
  costPerPlayer Float?
  isPrivate    Boolean    @default(false)
  status       GameStatus @default(OPEN)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sport        Sport                  @relation(fields: [sportId], references: [id])
  venue        Venue?                 @relation(fields: [venueId], references: [id])
  organizer    User                   @relation(fields: [organizerId], references: [id])
  participants PickupGameParticipant[]

  @@index([sportId, city, startAt])
  @@index([status])
}

model PickupGameParticipant {
  gameId   String
  userId   String
  joinedAt DateTime @default(now())
  team     String?

  game PickupGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gameId, userId])
}

// ─── Coaches ───

model Coach {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?  @db.Text
  headline        String?
  experience      Int?
  hourlyRate      Float
  certifications  String[] @default([])
  isVerified      Boolean  @default(false)
  isActive        Boolean  @default(true)
  avgRating       Float?
  totalReviews    Int      @default(0)
  totalSessions   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sports         CoachSport[]
  reviews        Review[]
  availability   CoachAvailability[]
  coachSessions  CoachSession[]
  academyCoaches AcademyCoach[]
}

model CoachSport {
  coachId    String
  sportId    String
  skillLevel String?

  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([coachId, sportId])
}

model CoachAvailability {
  id        String    @id @default(cuid())
  coachId   String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isActive  Boolean   @default(true)

  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, dayOfWeek, startTime])
}

model CoachSession {
  id        String   @id @default(cuid())
  coachId   String
  studentId String
  sportId   String?
  title     String?
  startAt   DateTime
  endAt     DateTime
  notes     String?  @db.Text
  status    BookingStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach   Coach    @relation(fields: [coachId], references: [id])
  student User     @relation("StudentSessions", fields: [studentId], references: [id])
  payment Payment?

  @@index([coachId, startAt])
}

// ─── Reviews ───

model Review {
  id        String   @id @default(cuid())
  coachId   String?
  venueId   String?
  userId    String
  rating    Int
  title     String?
  comment   String?  @db.Text
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach Coach? @relation(fields: [coachId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coachId, userId])
  @@index([venueId])
}

// ─── Academies ───

model Academy {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  address     String?
  city        String
  state       String
  zipCode     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  coverImage  String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User           @relation(fields: [ownerId], references: [id])
  sports      AcademySport[]
  coaches     AcademyCoach[]
  batches     Batch[]

  @@index([city, state])
}

model AcademySport {
  academyId String
  sportId   String

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  sport   Sport   @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([academyId, sportId])
}

model AcademyCoach {
  academyId String
  coachId   String
  role      String?
  joinedAt  DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  coach   Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@id([academyId, coachId])
}

model Batch {
  id          String   @id @default(cuid())
  academyId   String
  name        String
  description String?  @db.Text
  sportId     String?
  skillLevel  String?
  maxStudents Int
  schedule    String?
  startDate   DateTime?
  endDate     DateTime?
  monthlyFee  Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy     Academy      @relation(fields: [academyId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  attendances Attendance[]
}

model Enrollment {
  id          String           @id @default(cuid())
  batchId     String
  studentId   String
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt

  batch   Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User     @relation(fields: [studentId], references: [id])
  payment Payment?

  @@unique([batchId, studentId])
}

model Attendance {
  id        String           @id @default(cuid())
  batchId   String
  studentId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id])

  @@unique([batchId, studentId, date])
}

// ─── Events & Tournaments ───

model Event {
  id               String      @id @default(cuid())
  title            String
  slug             String      @unique
  description      String?     @db.Text
  type             EventType
  sportId          String
  venueId          String?
  organizerId      String?
  city             String?
  state            String?
  startDate        DateTime
  endDate          DateTime
  registrationDeadline DateTime?
  maxParticipants  Int?
  entryFee         Float?
  prizePool        Float?
  rules            String?     @db.Text
  bannerImage      String?
  status           EventStatus @default(DRAFT)
  isPublic         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  sport          Sport               @relation(fields: [sportId], references: [id])
  venue          Venue?              @relation(fields: [venueId], references: [id])
  registrations  EventRegistration[]
  teams          Team[]
  matches        Match[]

  @@index([sportId, city, startDate])
  @@index([status])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  teamId    String?
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime @default(now())

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  team    Team?    @relation(fields: [teamId], references: [id])
  payment Payment?

  @@unique([eventId, userId])
}

model Team {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  seed      Int?
  createdAt DateTime @default(now())

  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
  homeMatches   Match[]             @relation("HomeTeam")
  awayMatches   Match[]             @relation("AwayTeam")
  wonMatches    Match[]             @relation("WinnerTeam")
}

model Match {
  id          String      @id @default(cuid())
  eventId     String
  round       Int
  matchNumber Int
  homeTeamId  String?
  awayTeamId  String?
  winnerId    String?
  homeScore   Int?
  awayScore   Int?
  startAt     DateTime?
  status      MatchStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  homeTeam Team?  @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team?  @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner   Team?  @relation("WinnerTeam", fields: [winnerId], references: [id])

  @@index([eventId, round])
}

// ─── Social Features ───

model Group {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  image       String?
  city        String?
  isPublic    Boolean  @default(true)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User          @relation(fields: [ownerId], references: [id])
  members  GroupMember[]
  messages Message[]     @relation("GroupMessages")
}

model GroupMember {
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String?
  groupId    String?
  content    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User   @relation("SentMessages", fields: [senderId], references: [id])
  receiver User?  @relation("ReceivedMessages", fields: [receiverId], references: [id])
  group    Group? @relation("GroupMessages", fields: [groupId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([groupId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  type      String
  targetId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
}

// ─── Achievements & Gamification ───

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  criteria    Json?
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  players PlayerBadge[]
}

model PlayerBadge {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model Leaderboard {
  id       String @id @default(cuid())
  userId   String
  sportId  String?
  city     String?
  points   Int    @default(0)
  gamesPlayed Int @default(0)
  wins     Int    @default(0)
  period   String @default("alltime")

  @@unique([userId, sportId, city, period])
  @@index([points(sort: Desc)])
}

// ─── Blog / Content ───

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  authorId    String
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([isPublished, publishedAt])
}

// ─── Notifications ───

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Admin / Platform ───

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
